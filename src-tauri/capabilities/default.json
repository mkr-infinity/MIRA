{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for MIRA",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    "core:app:default",
    "opener:default",
    "opener:allow-open-url",
    "opener:allow-open-path",
    "shell:default",
    "shell:allow-open",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-read-dir",
    "fs:allow-app-read",
    "fs:allow-app-write",
    "fs:allow-app-meta",
    "fs:allow-desktop-read",
    "fs:allow-desktop-write",
    "fs:allow-desktop-meta",
    "dialog:default"
  ]
}
